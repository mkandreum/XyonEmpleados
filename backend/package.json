{
  "name": "xyonempleados-backend",
  "version": "1.0.0",
  "description": "Backend API for XyonEmpleados Portal",
  "main": "src/server.js",
  "scripts": {
    "start": "npm run prisma:migrate && node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "node prisma/runMigrations.js",
    "seed": "node prisma/seed.js",
    "build": "npm run prisma:generate && npm run prisma:migrate && echo 'Build complete'",
    "postinstall": "node -e \"const fs=require('fs');const {execSync}=require('child_process');if(fs.existsSync('prisma/schema.prisma')) execSync('npm run prisma:generate',{stdio:'inherit'});\""
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.7",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^6.4.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
