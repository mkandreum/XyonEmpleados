# Copy to .env for local compose testing, or set these in Coolify Variables

APP_PORT=3000
POSTGRES_USER=postgres
POSTGRES_DB=xyonempleados_db

JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
ADMIN_EMAIL=admin@xyonempleados.com
ADMIN_INITIAL_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Optional (recommended in production with custom domain)
# FRONTEND_URL=https://tu-dominio.com

# NOTE:
# DB password is generated automatically and persisted in volume `db_auth`.
# Do not set POSTGRES_PASSWORD or DATABASE_URL manually in this automatic mode.
